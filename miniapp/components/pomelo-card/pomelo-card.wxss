/* 金柚卡片组件样式 */
.pomelo-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 12rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 头部：左图右文 */
.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.card-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f5efe4;
  flex-shrink: 0;
}

.card-title-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  overflow: hidden;
}

.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2c2416;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-origin {
  font-size: 24rpx;
  color: #9b8b70;
}

.card-price {
  font-size: 26rpx;
  color: #d9504a;
  font-weight: 500;
}

/* 评分 */
.card-scores {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.score-label {
  font-size: 24rpx;
  color: #9b8b70;
}

.score-stars {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 28rpx;
  color: #ede4d2;
}

.star.active {
  color: #c4a265;
}

.score-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #d9504a;
  margin-left: auto;
}

/* 标签 */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tag {
  font-size: 22rpx;
  color: #a6844a;
  background: #faf5eb;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* 推荐理由 */
.card-reason {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #fdf8f0;
  border-radius: 10rpx;
  border-left: 4rpx solid #d9504a;
}

.reason-icon {
  font-size: 26rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.reason-text {
  font-size: 26rpx;
  color: #4a3a28;
  line-height: 1.6;
}

/* 底部按钮 */
.card-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.detail-btn {
  font-size: 26rpx;
  color: #d9504a;
  padding: 8rpx 20rpx;
  border: 1rpx solid #d9504a;
  border-radius: 30rpx;
}
