/* ==================================================
   AI智荐对话页面 样式
   ================================================== */

/* 页面容器 */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f6f3ea; /* 客家米色底 */
}

/* ==================== 对话滚动区 ==================== */

.chat-scroll {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

.chat-bottom-spacer {
  height: 30rpx;
}

/* 欢迎页 */
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}

.welcome-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  background: #e0d5b7;
}

.welcome-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #5a4636;
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #9b8b6f;
}

/* ==================== 消息行 ==================== */

.msg-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: 28rpx;
  gap: 16rpx;
}

/* 用户消息：右对齐 */
.msg-row-user {
  flex-direction: row-reverse;
}

/* 头像 */
.msg-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.msg-avatar image {
  width: 100%;
  height: 100%;
}

.msg-avatar-user {
  background: #e8684a;
}

.msg-avatar-ai {
  background: #d4a843;
}

/* ==================== 气泡 ==================== */

.msg-bubble {
  max-width: 78%;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  position: relative;
}

/* 用户气泡（右侧，客家红调） */
.msg-bubble-user {
  background: linear-gradient(135deg, #e8684a 0%, #d48560 100%);
  border-top-right-radius: 6rpx;
}

.msg-bubble-user .msg-text {
  color: #fff;
  font-size: 30rpx;
  line-height: 1.6;
  word-break: break-all;
}

/* AI 气泡（左侧，白色） */
.msg-bubble-ai {
  background: #fff;
  border-top-left-radius: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.msg-bubble-ai .msg-text {
  color: #3d3226;
  font-size: 30rpx;
  line-height: 1.7;
  word-break: break-all;
}

/* AI 卡片类型气泡（更宽） */
.msg-bubble-card {
  max-width: 90%;
  padding: 24rpx;
  background: #fafaf7;
  border: 1rpx solid #ebe4d0;
}

.msg-summary {
  margin-bottom: 8rpx;
  font-weight: 500;
}

/* ==================== 加载动画 ==================== */

.msg-bubble-loading {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 28rpx;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.typing-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #d4a843;
  animation: typing-bounce 1.4s infinite ease-in-out both;
}

.typing-dot:nth-child(1) { animation-delay: 0s; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing-bounce {
  0%, 60%, 100% {
    transform: scale(0.6);
    opacity: 0.5;
  }
  30% {
    transform: scale(1);
    opacity: 1;
  }
}

.loading-text {
  font-size: 26rpx;
  color: #b0a080;
}

/* ==================== 快捷提问 ==================== */

.quick-asks {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.quick-btn {
  font-size: 28rpx;
  color: #d4a843;
  background: #fef9ed;
  border: 1rpx solid #ecd9a2;
  border-radius: 30rpx;
  padding: 14rpx 24rpx;
  text-align: center;
}

.quick-btn:active {
  background: #fdf0d0;
}

/* ==================== 模式切换 ==================== */
.mode-bar {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 24rpx;
  background: #fff;
  border-top: 1rpx solid #f0ece0;
}
.mode-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #999;
  background: #f5f2e8;
}
.mode-active {
  background: #d4a843;
  color: #fff;
  font-weight: 600;
}

/* ==================== 底部输入栏 ==================== */

.input-bar {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #ece4d0;
  gap: 16rpx;
}

.input-box {
  flex: 1;
  background: #f5f2e8;
  border-radius: 36rpx;
  padding: 6rpx 6rpx 6rpx 28rpx;
}

.input-textarea {
  width: 100%;
  min-height: 40rpx;
  max-height: 140rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #3d3226;
}

.send-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #e0d5b7;
  flex-shrink: 0;
  transition: background 0.25s;
}

.send-btn text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.send-btn-active {
  background: #d4a843;
}

.send-btn-active:active {
  background: #c49635;
}

/* ==================== 其他 ==================== */

.msg-time {
  font-size: 22rpx;
  color: #b0a080;
  margin-top: 8rpx;
  text-align: center;
}
