.page { background: #fefcf7; padding-bottom: 120rpx; }
.hero-img { width: 100%; height: 420rpx; background: #c4b8a2; }
.info-card { background: #fff; margin: -30rpx 24rpx 20rpx; border-radius: 20rpx; padding: 28rpx; position: relative; }
.name { font-size: 36rpx; font-weight: 700; color: #2c2416; display: block; margin-bottom: 20rpx; }
.meta { display: flex; flex-wrap: wrap; gap: 0; }
.meta-item { width: 50%; padding: 12rpx 0; border-bottom: 1rpx solid #f5efe4; }
.meta-label { font-size: 24rpx; color: #c4b8a2; display: block; }
.meta-val { font-size: 28rpx; color: #2c2416; display: block; margin-top: 4rpx; }
.meta-val.price { color: #d9504a; font-weight: 600; }

.tags { display: flex; flex-wrap: wrap; gap: 12rpx; padding: 0 24rpx 20rpx; }
.tag { background: #faf5eb; color: #a6844a; font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 20rpx; }

.section { background: #fff; margin: 0 24rpx 16rpx; border-radius: 16rpx; padding: 24rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #4a3a28; margin-bottom: 12rpx; display: block; }
.section-text { font-size: 28rpx; color: #2c2416; line-height: 1.8; }
.scores { display: flex; flex-direction: column; gap: 8rpx; font-size: 26rpx; color: #9b8b70; }

.empty { text-align: center; padding: 120rpx 0; color: #c4b8a2; }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom)); background: #fff; border-top: 1rpx solid #ede4d2; }
.btn-ask { background: #d9504a; color: #fff; border-radius: 36rpx; font-size: 30rpx; font-weight: 600; }
