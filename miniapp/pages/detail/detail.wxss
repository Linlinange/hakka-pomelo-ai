.page { background: #f6f3ea; padding-bottom: 120rpx; }
.hero-img { width: 100%; height: 420rpx; background: #e0d5b7; }
.info-card { background: #fff; margin: -30rpx 24rpx 20rpx; border-radius: 20rpx; padding: 28rpx; position: relative; }
.name { font-size: 36rpx; font-weight: 700; color: #3d3226; display: block; margin-bottom: 20rpx; }
.meta { display: flex; flex-wrap: wrap; gap: 0; }
.meta-item { width: 50%; padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.meta-label { font-size: 24rpx; color: #999; display: block; }
.meta-val { font-size: 28rpx; color: #3d3226; display: block; margin-top: 4rpx; }
.meta-val.price { color: #e8684a; font-weight: 600; }

.tags { display: flex; flex-wrap: wrap; gap: 12rpx; padding: 0 24rpx 20rpx; }
.tag { background: #fef7e0; color: #b8860b; font-size: 24rpx; padding: 8rpx 20rpx; border-radius: 20rpx; }

.section { background: #fff; margin: 0 24rpx 16rpx; border-radius: 16rpx; padding: 24rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #5a4636; margin-bottom: 12rpx; display: block; }
.section-text { font-size: 28rpx; color: #3d3226; line-height: 1.8; }
.scores { display: flex; flex-direction: column; gap: 8rpx; font-size: 26rpx; color: #666; }

.empty { text-align: center; padding: 120rpx 0; color: #999; }

.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom)); background: #fff; border-top: 1rpx solid #ece4d0; }
.btn-ask { background: #d4a843; color: #fff; border-radius: 36rpx; font-size: 30rpx; font-weight: 600; }
