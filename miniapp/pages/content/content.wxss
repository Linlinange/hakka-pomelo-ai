.page { padding: 24rpx; }

.scene-tabs { display: flex; gap: 20rpx; margin-bottom: 30rpx; }
.scene-tab { flex: 1; text-align: center; padding: 24rpx; border-radius: 16rpx; background: #fff; font-size: 28rpx; color: #666; }
.scene-tab.active { background: #d4a843; color: #fff; font-weight: 600; }

.form { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; }
.form-item { margin-bottom: 20rpx; }
.label { font-size: 26rpx; color: #666; margin-bottom: 10rpx; display: block; }
.input { border: 1rpx solid #ece4d0; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; }
.textarea { border: 1rpx solid #ece4d0; border-radius: 12rpx; padding: 16rpx 20rpx; font-size: 28rpx; min-height: 140rpx; width: 100%; box-sizing: border-box; }
.gen-btn { background: #d4a843; color: #fff; border-radius: 36rpx; font-size: 30rpx; font-weight: 600; margin-top: 10rpx; }

.result { background: #fff; border-radius: 16rpx; padding: 24rpx; }
.result-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.result-scene { font-size: 24rpx; color: #d4a843; background: #fef9ed; padding: 6rpx 16rpx; border-radius: 20rpx; }
.result-time { font-size: 22rpx; color: #bbb; }
.result-content { font-size: 28rpx; line-height: 1.8; color: #3d3226; white-space: pre-wrap; }
.result-actions { margin-top: 20rpx; display: flex; justify-content: flex-end; }
.copy-btn { background: #faf8f0; color: #5a4636; font-size: 26rpx; border-radius: 30rpx; padding: 12rpx 32rpx; }
