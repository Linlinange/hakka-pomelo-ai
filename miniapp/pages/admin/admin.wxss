.page { background: #f6f3ea; min-height: 100vh; }

.tabs { display: flex; background: #fff; border-bottom: 1rpx solid #ece4d0; }
.tab { flex: 1; text-align: center; padding: 28rpx; font-size: 28rpx; color: #666; }
.tab.active { color: #d4a843; font-weight: 600; border-bottom: 4rpx solid #d4a843; }

.toolbar { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; }
.count { font-size: 24rpx; color: #999; }
.add-btn { background: #d4a843; color: #fff; }

.list { padding: 0 24rpx; }
.list-item { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; display: flex; justify-content: space-between; align-items: center; }
.item-info { flex: 1; overflow: hidden; }
.item-name { font-size: 28rpx; font-weight: 600; color: #3d3226; display: block; }
.tag-scene { font-size: 20rpx; background: #fef7e0; color: #b8860b; padding: 2rpx 10rpx; border-radius: 8rpx; margin-left: 10rpx; }
.item-sub { font-size: 24rpx; color: #999; margin-top: 6rpx; display: block; }
.item-actions { display: flex; gap: 20rpx; flex-shrink: 0; }
.action-edit { color: #d4a843; font-size: 26rpx; }
.action-del { color: #e8684a; font-size: 26rpx; }

/* Modal */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 100; display: flex; align-items: center; justify-content: center; }
.modal { width: 86vw; background: #fff; border-radius: 20rpx; padding: 32rpx; max-height: 80vh; overflow-y: auto; }
.modal-title { font-size: 32rpx; font-weight: 600; color: #3d3226; margin-bottom: 24rpx; display: block; }
.form-input { border: 1rpx solid #ece4d0; border-radius: 12rpx; padding: 16rpx; margin-bottom: 16rpx; font-size: 28rpx; }
.form-textarea { border: 1rpx solid #ece4d0; border-radius: 12rpx; padding: 16rpx; margin-bottom: 16rpx; font-size: 28rpx; min-height: 120rpx; width: 100%; box-sizing: border-box; }
.modal-btns { display: flex; gap: 20rpx; }
.btn-cancel { flex: 1; background: #f5f5f5; border-radius: 30rpx; font-size: 28rpx; }
.btn-save { flex: 1; background: #d4a843; color: #fff; border-radius: 30rpx; font-size: 28rpx; }
