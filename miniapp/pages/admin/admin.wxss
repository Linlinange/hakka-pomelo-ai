.page { background: #fefcf7; min-height: 100vh; }

.tabs { display: flex; background: #fff; border-bottom: 1rpx solid #ede4d2; }
.tab { flex: 1; text-align: center; padding: 28rpx; font-size: 28rpx; color: #9b8b70; }
.tab.active { color: #d9504a; font-weight: 600; border-bottom: 4rpx solid #d9504a; }

.toolbar { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; }
.count { font-size: 24rpx; color: #c4b8a2; }
.add-btn { background: #d9504a; color: #fff; }

.list { padding: 0 24rpx; }
.list-item { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 16rpx; display: flex; justify-content: space-between; align-items: center; }
.item-info { flex: 1; overflow: hidden; }
.item-name { font-size: 28rpx; font-weight: 600; color: #2c2416; display: block; }
.tag-scene { font-size: 20rpx; background: #faf5eb; color: #a6844a; padding: 2rpx 10rpx; border-radius: 8rpx; margin-left: 10rpx; }
.item-sub { font-size: 24rpx; color: #c4b8a2; margin-top: 6rpx; display: block; }
.item-actions { display: flex; gap: 20rpx; flex-shrink: 0; }
.action-edit { color: #d9504a; font-size: 26rpx; }
.action-del { color: #d9504a; font-size: 26rpx; }

/* Modal */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 100; display: flex; align-items: center; justify-content: center; }
.modal { width: 86vw; background: #fff; border-radius: 20rpx; padding: 32rpx; max-height: 80vh; overflow-y: auto; }
.modal-title { font-size: 32rpx; font-weight: 600; color: #2c2416; margin-bottom: 24rpx; display: block; }
.form-input { border: 1rpx solid #ede4d2; border-radius: 12rpx; padding: 16rpx; margin-bottom: 16rpx; font-size: 28rpx; }
.form-textarea { border: 1rpx solid #ede4d2; border-radius: 12rpx; padding: 16rpx; margin-bottom: 16rpx; font-size: 28rpx; min-height: 120rpx; width: 100%; box-sizing: border-box; }
.modal-btns { display: flex; gap: 20rpx; }
.btn-cancel { flex: 1; background: #f5efe4; border-radius: 30rpx; font-size: 28rpx; }
.btn-save { flex: 1; background: #d9504a; color: #fff; border-radius: 30rpx; font-size: 28rpx; }
