.page { padding: 24rpx; }
.no-login { display: flex; flex-direction: column; align-items: center; padding-top: 140rpx; }
.avatar-placeholder { width: 140rpx; height: 140rpx; border-radius: 50%; background: #c4b8a2; margin-bottom: 24rpx; }
.login-tip { font-size: 28rpx; color: #c4b8a2; margin-bottom: 30rpx; }
.login-btn { background: #d9504a; color: #fff; border-radius: 36rpx; font-size: 30rpx; }

.profile-card { display: flex; align-items: center; gap: 24rpx; background: #fff; border-radius: 20rpx; padding: 32rpx; margin-bottom: 24rpx; }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; }
.nickname { font-size: 34rpx; font-weight: 600; color: #2c2416; display: block; }
.uid { font-size: 24rpx; color: #c4b8a2; margin-top: 6rpx; display: block; }

.menu-list { background: #fff; border-radius: 20rpx; overflow: hidden; margin-bottom: 40rpx; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 32rpx; font-size: 30rpx; border-bottom: 1rpx solid #f5efe4; }
.arrow { color: #c4b8a2; }

.history { margin: 0 0 24rpx; }
.history-title { font-size: 28rpx; font-weight: 600; color: #4a3a28; padding: 0 8rpx 16rpx; display: block; }
.history-item { background: #fff; border-radius: 12rpx; padding: 20rpx 24rpx; margin-bottom: 10rpx; }
.history-query { font-size: 26rpx; color: #2c2416; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.history-time { font-size: 22rpx; color: #c4b8a2; margin-top: 6rpx; display: block; }

.logout-btn { text-align: center; padding: 24rpx; color: #d9504a; font-size: 28rpx; }
