.page { padding: 32rpx; }

.hero { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0 40rpx; }
.hero-logo { width: 140rpx; height: 140rpx; border-radius: 28rpx; background: #e0d5b7; margin-bottom: 20rpx; }
.hero-title { font-size: 40rpx; font-weight: 700; color: #5a4636; }
.hero-desc { font-size: 26rpx; color: #9b8b6f; margin-top: 10rpx; }

.cards { display: flex; gap: 24rpx; margin-bottom: 40rpx; }
.card { flex: 1; background: #fff; border-radius: 20rpx; padding: 32rpx 24rpx; text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.card-icon { font-size: 56rpx; display: block; margin-bottom: 14rpx; }
.card-title { font-size: 32rpx; font-weight: 600; color: #3d3226; display: block; margin-bottom: 8rpx; }
.card-desc { font-size: 24rpx; color: #999; display: block; }

.section { margin-bottom: 32rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #5a4636; margin-bottom: 16rpx; display: block; }
.quick-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.quick-item { background: #fff; border: 1rpx solid #ece4d0; border-radius: 30rpx; padding: 16rpx 28rpx; font-size: 28rpx; color: #5a4636; }
.quick-item:active { background: #fdf0d0; }

.admin-entry { margin-top: 20rpx; text-align: center; padding: 24rpx; background: #faf8f0; border-radius: 16rpx; font-size: 26rpx; color: #b0a080; }
