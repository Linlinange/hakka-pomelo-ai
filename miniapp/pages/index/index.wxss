.page { padding: 32rpx; }

.hero { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0 40rpx; }
.hero-logo { width: 140rpx; height: 140rpx; border-radius: 28rpx; background: #c4b8a2; margin-bottom: 20rpx; }
.hero-title { font-size: 40rpx; font-weight: 700; color: #4a3a28; }
.hero-desc { font-size: 26rpx; color: #9b8b70; margin-top: 10rpx; }

.cards { display: flex; gap: 24rpx; margin-bottom: 40rpx; }
.card { flex: 1; background: #fff; border-radius: 20rpx; padding: 32rpx 24rpx; text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.card-icon { font-size: 56rpx; display: block; margin-bottom: 14rpx; }
.card-title { font-size: 32rpx; font-weight: 600; color: #2c2416; display: block; margin-bottom: 8rpx; }
.card-desc { font-size: 24rpx; color: #c4b8a2; display: block; }

.section { margin-bottom: 32rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #4a3a28; margin-bottom: 16rpx; display: block; }
.quick-list { display: flex; flex-wrap: wrap; gap: 16rpx; }
.quick-item { background: #fff; border: 1rpx solid #ede4d2; border-radius: 30rpx; padding: 16rpx 28rpx; font-size: 28rpx; color: #4a3a28; }
.quick-item:active { background: #faf5eb; }

.admin-entry { margin-top: 20rpx; text-align: center; padding: 24rpx; background: #fdf8f0; border-radius: 16rpx; font-size: 26rpx; color: #c4b8a2; }
