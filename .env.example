# ============================================================
# 客家金柚AI智荐系统 — 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---- 大模型 API（Python AI 层使用） ----
# DeepSeek（必需，默认模型）
DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_ENDPOINT=https://api.deepseek.com/chat/completions

# ChatGLM（可选）
# CHATGLM_API_KEY=your-chatglm-key
# CHATGLM_ENDPOINT=https://open.bigmodel.cn/api/paas/v4/chat/completions

# 讯飞星火（可选）
# SPARK_APP_ID=your-spark-app-id
# SPARK_API_KEY=your-spark-api-key
# SPARK_API_SECRET=your-spark-api-secret

# ---- 数据库（Python + Java 共用） ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=golden_pomelo_ai

# ---- Redis（Java 后端使用） ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Python AI 层地址（Java 后端调用） ----
AI_LAYER_URL=http://127.0.0.1:5000

# ---- 微信小程序（Java 后端使用） ----
# WECHAT_APP_ID=your-wechat-app-id
# WECHAT_APP_SECRET=your-wechat-app-secret
